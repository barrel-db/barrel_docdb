{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{deps, [
    {rocksdb, "2.5.0"},
    {barrel_docdb, {git, "https://gitlab.com/barrel-db/barrel_docdb.git", {branch, "main"}}}
]}.

%% NOTE: barrel_docdb is linked via _checkouts/barrel_docdb for local development
%% The git dep is just for dependency resolution; _checkouts takes precedence

{shell, [
    {apps, [barrel_bench]}
]}.
