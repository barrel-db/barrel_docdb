{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_unused_vars,
    warn_export_all
]}.

{deps, [
    {rocksdb, "2.2.0"},
    {mimerl, "1.3.0"},
    {hlc, {git, "https://gitlab.com/barrel-db/hlc.git", {tag, "3.0.1"}}},
    {match_trie, {git, "https://gitlab.com/barrel-db/match_trie.git", {tag, "0.1.0"}}},
    {bitmap, {git, "https://gitlab.com/barrel-db/bitmap.git", {branch, "master"}}}
]}.

{project_plugins, [
    rebar3_hex,
    rebar3_ex_doc
]}.

%% EUnit configuration
{eunit_opts, [verbose]}.
{cover_enabled, true}.

%% Common Test configuration
{ct_opts, [{verbose, true}]}.

%% Shell configuration for development
{shell, [
    {apps, [barrel_docdb]}
]}.

%% Dialyzer configuration
{dialyzer, [
    {warnings, [
        unmatched_returns,
        error_handling,
        unknown
    ]},
    {plt_extra_apps, [rocksdb]}
]}.

%% HexDocs configuration
{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {source_url, <<"https://gitlab.com/barrel-db/barrel_docdb">>},
    {extras, [
        <<"README.md">>,
        <<"DESIGN.md">>,
        <<"guides/getting_started.md">>,
        <<"guides/document_format.md">>,
        <<"guides/query.md">>,
        <<"guides/changes.md">>,
        <<"guides/replication.md">>,
        <<"LICENSE">>
    ]},
    {groups_for_extras, [
        {<<"Guides">>, [
            <<"guides/getting_started.md">>,
            <<"guides/document_format.md">>,
            <<"guides/query.md">>,
            <<"guides/changes.md">>,
            <<"guides/replication.md">>
        ]},
        {<<"Architecture">>, [
            <<"DESIGN.md">>
        ]}
    ]},
    {groups_for_modules, [
        {<<"Public API">>, [barrel_docdb, barrel_rep]},
        {<<"Query">>, [barrel_query]},
        {<<"Subscriptions">>, [barrel_sub, barrel_query_sub]},
        {<<"Replication">>, [
            barrel_rep_transport,
            barrel_rep_transport_local,
            barrel_rep_checkpoint,
            barrel_rep_alg
        ]},
        {<<"Views">>, [barrel_view, barrel_view_index]},
        {<<"Changes">>, [barrel_changes, barrel_changes_stream]},
        {<<"HLC">>, [barrel_hlc]},
        {<<"Storage">>, [barrel_store_rocksdb, barrel_store_keys, barrel_ars]},
        {<<"Internals">>, [
            barrel_db_server,
            barrel_db_sup,
            barrel_doc,
            barrel_revtree,
            barrel_att,
            barrel_att_store
        ]}
    ]},
    {main, <<"readme">>},
    {api_reference, true}
]}.

%% Release configuration
{relx, [
    {release, {barrel_docdb, "0.1.0"}, [
        barrel_docdb,
        sasl
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true},
    {sys_config, "config/sys.config"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true}
        ]}
    ]},
    {test, [
        {deps, [
            {meck, "0.9.2"}
        ]}
    ]}
]}.
