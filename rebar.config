{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_unused_vars,
    warn_export_all
]}.

{deps, [
    {rocksdb, "2.5.0"},
    {mimerl, "1.3.0"},
    {hlc, {git, "https://gitlab.com/barrel-db/hlc.git", {tag, "3.0.1"}}},
    {match_trie, {git, "https://gitlab.com/barrel-db/match_trie.git", {tag, "0.1.0"}}},
    {bitmap, {git, "https://gitlab.com/barrel-db/bitmap.git", {branch, "master"}}},
    %% HTTP transport for P2P replication
    {cowboy, "2.12.0"},
    {hackney, "3.0.2"},
    %% Prometheus metrics
    {prometheus, "4.11.0"},
    %% JWT handling for barreldb-console tokens
    {jose, "1.11.10"}
]}.

{project_plugins, [
    rebar3_hex,
    rebar3_ex_doc
]}.

%% EUnit configuration
{eunit_opts, [verbose]}.
{cover_enabled, true}.

%% Common Test configuration
{ct_opts, [{verbose, true}]}.

%% Shell configuration for development
{shell, [
    {apps, [barrel_docdb]}
]}.

%% Dialyzer configuration
{dialyzer, [
    {warnings, [
        unmatched_returns,
        error_handling,
        unknown
    ]},
    {plt_extra_apps, [rocksdb]}
]}.

%% HexDocs configuration
{hex, [{doc, ex_doc}]}.

{ex_doc, [
    {source_url, <<"https://gitlab.com/barrel-db/barrel_docdb">>},
    {extras, [
        <<"README.md">>,
        <<"DESIGN.md">>,
        <<"guides/getting_started.md">>,
        <<"guides/document_format.md">>,
        <<"guides/query.md">>,
        <<"guides/changes.md">>,
        <<"guides/replication.md">>,
        <<"guides/features.md">>,
        <<"docs/vdb.md">>,
        <<"docs/sharding.md">>,
        <<"docs/benchmarks.md">>,
        <<"docs/federation.md">>,
        <<"docs/metrics.md">>,
        <<"docs/replication-policies.md">>,
        <<"docs/tiered-storage.md">>,
        <<"docs/advanced-features.md">>,
        <<"docs/api/erlang.md">>,
        <<"LICENSE">>
    ]},
    {groups_for_extras, [
        {<<"Guides">>, [
            <<"guides/getting_started.md">>,
            <<"guides/document_format.md">>,
            <<"guides/query.md">>,
            <<"guides/changes.md">>,
            <<"guides/replication.md">>,
            <<"guides/features.md">>
        ]},
        {<<"Architecture">>, [
            <<"DESIGN.md">>,
            <<"docs/sharding.md">>,
            <<"docs/vdb.md">>
        ]},
        {<<"Operations">>, [
            <<"docs/benchmarks.md">>,
            <<"docs/metrics.md">>,
            <<"docs/federation.md">>,
            <<"docs/replication-policies.md">>,
            <<"docs/tiered-storage.md">>,
            <<"docs/advanced-features.md">>
        ]},
        {<<"API Reference">>, [
            <<"docs/api/erlang.md">>
        ]}
    ]},
    {groups_for_modules, [
        {<<"Public API">>, [barrel_docdb, barrel_rep, barrel_vdb]},
        {<<"Query">>, [barrel_query]},
        {<<"Subscriptions">>, [barrel_sub, barrel_query_sub]},
        {<<"Replication">>, [
            barrel_rep_transport,
            barrel_rep_transport_local,
            barrel_rep_checkpoint,
            barrel_rep_alg
        ]},
        {<<"VDB (Virtual Databases)">>, [
            barrel_vdb,
            barrel_vdb_shard,
            barrel_vdb_router,
            barrel_vdb_manager
        ]},
        {<<"Views">>, [barrel_view, barrel_view_index]},
        {<<"Changes">>, [barrel_changes, barrel_changes_stream]},
        {<<"HLC">>, [barrel_hlc]},
        {<<"HTTP">>, [barrel_http_server, barrel_http_handler]},
        {<<"Storage">>, [barrel_store_rocksdb, barrel_store_keys, barrel_ars]},
        {<<"Internals">>, [
            barrel_db_server,
            barrel_db_sup,
            barrel_doc,
            barrel_revtree,
            barrel_att,
            barrel_att_store
        ]}
    ]},
    {main, <<"readme">>},
    {api_reference, true}
]}.

%% Release configuration
{relx, [
    {release, {barrel_docdb, "0.3.0"}, [
        barrel_docdb,
        sasl,
        cowboy,
        hackney,
        prometheus,
        jose,
        runtime_tools
    ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true},
    {sys_config, "config/sys.config"},
    {vm_args, "config/vm.args"},
    {overlay, [
        {mkdir, "data"},
        {mkdir, "log"}
    ]}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true},
            {sys_config_src, "config/sys.config.src"},
            {vm_args_src, "config/vm.args.src"}
        ]}
    ]},
    {test, [
        {deps, [
            {meck, "0.9.2"}
        ]}
    ]}
]}.
