[
    {barrel_docdb, [
        {data_dir, "data/barrel_docdb"},
        {default_store, barrel_store_rocksdb},
        %% HTTP server configuration
        {http_enabled, true},
        {http_port, 8080},
        {http_acceptors, 100},
        {http_max_connections, infinity},
        %% HTTP/2 and TLS configuration
        %% protocols: [http2, http] - both HTTP/2 and HTTP/1.1 (default)
        %% protocols: [http2] - HTTP/2 only
        %% protocols: [http] - HTTP/1.1 only
        {http_protocols, [http2, http]},
        %% TLS configuration (enables HTTPS with HTTP/2 ALPN when set)
        %% {http_certfile, "/path/to/cert.pem"},
        %% {http_keyfile, "/path/to/key.pem"},
        %% {http_cacertfile, "/path/to/ca.pem"},
        %% {http_verify, verify_none}  %% or verify_peer
        {http_tls_enabled, false},

        %% JWT authentication for barreldb-console tokens (optional)
        %% Tokens with bdb_ prefix are validated against this public key
        %% {console_public_key, "/path/to/console_public_key.pem"},
        %% or inline PEM:
        %% {console_public_key_pem, <<"-----BEGIN PUBLIC KEY-----\n...">>}
        %%
        %% Note: If not configured, bdb_ tokens will be rejected.
        %% API keys (ak_ prefix) continue to work regardless.
        %%
        %% JWT claims required:
        %% - typ: must be "docdb" for barrel_docdb
        %% - sub: workspace key ID
        %% - oid: organization ID
        %% - prm: permissions list (read, write, admin)
        %% - exp: expiry timestamp
        %% - wid: workspace ID (null for all workspaces)
        {jose_json_module, json},  %% Use OTP json module for jose

        %% Distributed Tracing Configuration
        %% Uses OpenTelemetry-compatible tracing via the instrument library
        %%
        %% Options:
        %% - {enabled, true | false} - Enable/disable tracing (default: true)
        %% - {exporter, none | console | otlp | {Module, Config}}
        %%   * none - no span export (tracing still works internally)
        %%   * console - print spans to stdout (for development/debugging)
        %%   * otlp - send spans to OTLP collector
        %%   * {Module, Config} - custom exporter module
        %% - {console_format, text | json} - format for console exporter (default: text)
        %% - {otlp_endpoint, "http://host:port"} - OTLP collector endpoint
        %%
        %% Example for development (console output):
        %% {tracing, [{enabled, true}, {exporter, console}]}
        %%
        %% Example for production (OTLP):
        %% {tracing, [{enabled, true}, {exporter, otlp}, {otlp_endpoint, "http://localhost:4318"}]}
        {tracing, [
            {enabled, true},
            {exporter, none}  %% Change to console or otlp in your deployment
        ]}
    ]},
    {kernel, [
        {logger_level, info},
        {logger, [
            {handler, default, logger_std_h, #{
                level => info,
                formatter => {logger_formatter, #{
                    template => [time, " [", level, "] ", pid, " ", msg, "\n"]
                }}
            }}
        ]}
    ]}
].
